{
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "node .claude/hooks/sync-env-example.js"
					}
				]
			}
		]
	},
	"ignorePatterns": [
      ".env",
      ".env.production",
	  ".env.development",
      ".env.local"
    ]
	
}
