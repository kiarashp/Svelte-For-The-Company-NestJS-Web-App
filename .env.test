# Playwright e2e config — read by playwright.config.ts (Node context, not $env/static/public).
# This file IS committed (see .gitignore's `!.env.test`) — non-secret only.
#
# Actual seeded role credentials (SEED_ADMIN_EMAIL/PASSWORD, SEED_AUTHOR_*, SEED_EDITOR_*,
# SEED_USER_*) go in `.env.test.local` instead — that file is gitignored (matches the `.env.*`
# pattern; the `!.env.test` exception only un-ignores this exact filename) so real passwords never
# get committed, even dev-only ones.

# Local NestJS backend the e2e run talks to.
PUBLIC_API_URL=http://localhost:3000
