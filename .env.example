# NestJS backend base URL (required)
PUBLIC_API_URL=http://localhost:3000

# Override the default site name
PUBLIC_SITE_NAME=

# Override the default tagline
PUBLIC_SITE_TAGLINE=

# Override the default logo URL
PUBLIC_SITE_LOGO_URL=

# Override the default support email
PUBLIC_SUPPORT_EMAIL=

# Social link: Twitter/X profile URL
PUBLIC_TWITTER_URL=

# Social link: LinkedIn profile URL
PUBLIC_LINKEDIN_URL=

# Social link: GitHub profile URL
PUBLIC_GITHUB_URL=

# google client id
PUBLIC_GOOGLE_CLIENT_ID=

# ci
CI=
